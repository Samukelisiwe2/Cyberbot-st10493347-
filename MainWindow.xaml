<Window x:Class="Cyberbot___st10493347_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cyber bot 36"
        Height="720"
        Width="1100"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="121"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <Image Source="/depositphotos_176577870-stock-illustration-cute-smiling-funny-robot-chat.jpg"
                   Width="128"
                   Height="107"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   RenderTransformOrigin="0.524,0.126"/>

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top">

                <Label Content="Chat bot UI"
                       Width="414"
                       Height="73"
                       HorizontalContentAlignment="Center"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="#FF253AEC"
                       FontFamily="Ravie"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,4,0,0">

                    <Image Source="/green dot.png"
                           Width="31"
                           Height="18"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           Margin="0,0,4,0"/>

                    <Label Content="Online"
                           Height="35"
                           FontWeight="Bold"
                           FontSize="18"
                           Padding="0"/>
                </StackPanel>
            </StackPanel>

            <Border Height="3"
                    Background="Black"
                    VerticalAlignment="Bottom"
                    Grid.ColumnSpan="3"/>
        </Grid>

        <!-- MAIN TABS -->
        <TabControl Grid.Row="1"
                    Margin="10"
                    FontSize="15">

            <!-- CHAT TAB -->
            <TabItem Header="Chat">
                <Grid Background="White">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="108"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="Black"
                            BorderThickness="1"
                            Background="#ECE5DD">

                        <ListBox x:Name="MessagesList"
                                 ItemsSource="{Binding Messages}"
                                 Background="#FFDDE8EC"
                                 BorderThickness="0"
                                 Padding="10"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,4">
                                        <StackPanel HorizontalAlignment="{Binding Alignment}"
                                                    MaxWidth="480">

                                            <Border Background="{Binding BubbleBackground}"
                                                    CornerRadius="{Binding BubbleCornerRadius}"
                                                    Padding="10"
                                                    BorderBrush="#DDDDDD"
                                                    BorderThickness="1">

                                                <StackPanel>
                                                    <TextBlock Text="{Binding Sender}"
                                                               FontSize="11"
                                                               FontWeight="Bold"
                                                               Foreground="{Binding SenderColor}"
                                                               Margin="0,0,0,3"/>

                                                    <TextBlock Text="{Binding Text}"
                                                               TextWrapping="Wrap"
                                                               FontSize="15"
                                                               Foreground="Black"/>
                                                </StackPanel>
                                            </Border>

                                            <TextBlock Text="{Binding Time}"
                                                       FontSize="10"
                                                       Foreground="#666666"
                                                       HorizontalAlignment="{Binding Alignment}"
                                                       Margin="5,2,5,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="77"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="140"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0"
                               Source="/girl.jpeg"
                               Width="62"
                               Height="75"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <TextBox x:Name="txtMessage"
                                 Grid.Column="1"
                                 Height="58"
                                 TextWrapping="Wrap"
                                 Text="Text Message ...."
                                 VerticalAlignment="Center"
                                 FontSize="22"
                                 Foreground="#FF5A5454"
                                 Padding="12"
                                 BorderBrush="Black"
                                 BorderThickness="1"
                                 GotFocus="txtMessage_GotFocus"
                                 LostFocus="txtMessage_LostFocus"
                                 KeyDown="txtMessage_KeyDown"/>

                        <Button x:Name="btnSend"
                                Grid.Column="2"
                                Content="Send"
                                Width="98"
                                Height="44"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,5,0,0"
                                FontWeight="Bold"
                                FontSize="16"
                                Click="btnSend_Click"
                                Background="#FF7FB9EF"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- TASK ASSISTANT TAB -->
            <TabItem Header="Task Assistant">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Background="#FFF8FBFF">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Task title" FontWeight="Bold"/>
                                <TextBox x:Name="txtTaskTitle"
                                         Height="35"
                                         FontSize="15"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="Description" FontWeight="Bold"/>
                                <TextBox x:Name="txtTaskDescription"
                                         Height="35"
                                         FontSize="15"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="Reminder" FontWeight="Bold"/>
                                <TextBox x:Name="txtTaskReminder"
                                         Height="35"
                                         FontSize="15"/>
                            </StackPanel>

                            <Button Grid.Column="3"
                                    x:Name="btnAddTask"
                                    Content="Add Task"
                                    Height="38"
                                    VerticalAlignment="Bottom"
                                    FontWeight="Bold"
                                    Click="btnAddTask_Click"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="TasksGrid"
                              Grid.Row="1"
                              Margin="0,12,0,12"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="180"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Reminder" Binding="{Binding Reminder}" Width="180"/>
                            <DataGridCheckBoxColumn Header="Complete" Binding="{Binding IsComplete}" Width="90"/>
                            <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button x:Name="btnCompleteTask"
                                Content="Mark Complete"
                                Width="140"
                                Height="38"
                                Margin="0,0,10,0"
                                Click="btnCompleteTask_Click"/>

                        <Button x:Name="btnDeleteTask"
                                Content="Delete Task"
                                Width="120"
                                Height="38"
                                Click="btnDeleteTask_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- QUIZ TAB -->
            <TabItem Header="Quiz">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <TextBlock x:Name="txtQuizScore"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Text="Score: 0"
                                   Margin="0,0,20,0"/>

                        <Button x:Name="btnStartQuiz"
                                Content="Start Quiz"
                                Width="120"
                                Height="35"
                                FontWeight="Bold"
                                Click="btnStartQuiz_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="txtQuizQuestion"
                               Grid.Row="1"
                               Text="Click Start Quiz to begin."
                               FontSize="22"
                               FontWeight="Bold"
                               TextWrapping="Wrap"
                               Margin="0,25,0,15"/>

                    <StackPanel Grid.Row="2">
                        <RadioButton x:Name="rbOptionA"
                                     FontSize="17"
                                     Margin="0,8"
                                     GroupName="QuizOptions"/>

                        <RadioButton x:Name="rbOptionB"
                                     FontSize="17"
                                     Margin="0,8"
                                     GroupName="QuizOptions"/>

                        <RadioButton x:Name="rbOptionC"
                                     FontSize="17"
                                     Margin="0,8"
                                     GroupName="QuizOptions"/>

                        <RadioButton x:Name="rbOptionD"
                                     FontSize="17"
                                     Margin="0,8"
                                     GroupName="QuizOptions"/>

                        <TextBlock x:Name="txtQuizFeedback"
                                   FontSize="17"
                                   TextWrapping="Wrap"
                                   Margin="0,25,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button x:Name="btnSubmitAnswer"
                                Content="Submit Answer"
                                Width="140"
                                Height="38"
                                Margin="0,0,10,0"
                                Click="btnSubmitAnswer_Click"
                                IsEnabled="False"/>

                        <Button x:Name="btnNextQuestion"
                                Content="Next Question"
                                Width="140"
                                Height="38"
                                Click="btnNextQuestion_Click"
                                IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ACTIVITY LOG TAB -->
            <TabItem Header="Activity Log">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="txtActivityLog"
                             Grid.Row="0"
                             FontFamily="Consolas"
                             FontSize="15"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"/>

                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,10,0,0">

                        <Button x:Name="btnRefreshLog"
                                Content="Refresh Last 10"
                                Width="130"
                                Height="36"
                                Margin="0,0,10,0"
                                Click="btnRefreshLog_Click"/>

                        <Button x:Name="btnShowMoreLog"
                                Content="Show More"
                                Width="110"
                                Height="36"
                                Click="btnShowMoreLog_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>